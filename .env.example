# Web/API authentication
# Set this before exposing the dashboard outside localhost.
QUANT_SYSTEM_API_KEY=
APP_ENV=development

# OpenAI-compatible LLM settings
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5

# Full OpenClaw Gateway service. Keep OpenClaw as its native full service,
# while this app provides user workspaces, permissions, audit, and quant tools.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_WEB_URL=http://127.0.0.1:18789
OPENCLAW_API_KEY=
# Keep disabled by default for deployment safety. Enable only for local managed-wrapper development.
OPENCLAW_MANAGED=false
OPENCLAW_AUTO_START=false
OPENCLAW_STOP_ON_EXIT=false
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_WORK_DIR=./data/openclaw
OPENCLAW_LOG_DIR=./logs/openclaw
OPENCLAW_NPM_PACKAGE=./openclaw-2026.5.20.tgz
OPENCLAW_INSTALL_TIMEOUT=180
OPENCLAW_CHAT_TIMEOUT=60
OPENCLAW_ENABLE_LOCAL_FALLBACK=false

# Optional initial 6-character invite code. Defaults to LOCAL1 for local dev.
QUANT_DEFAULT_INVITE_CODE=LOCAL1

# Data source settings
DATA_SOURCE_MODE=new
MOOTDX_SERVERS=
IWENCAI_COOKIE=
SHADOW_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=INFO
